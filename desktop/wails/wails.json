{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "enbu-desktop",
  "outputfilename": "enbu-desktop",
  "frontend:dir": "../../web",
  "frontend:install": "vp install --frozen-lockfile",
  "frontend:build": "vp run build",
  "frontend:dev:watcher": "vp run dev",
  "frontend:dev:serverUrl": "http://localhost:5173",
  "assetdir": "../../web/dist",
  "wailsjsdir": "../../web/src",
  "info": {
    "protocols": [
      {
        "scheme": "enbu",
        "description": "Open enbu desktop",
        "role": "Viewer"
      }
    ]
  }
}
